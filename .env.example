# Copy this file to ".env" and fill in your token.
# Vue CLI only exposes variables prefixed with VUE_APP_ to the app.
# The token is read at build/serve time and injected as process.env.VUE_APP_HF_TOKEN.

# Hugging Face access token: https://huggingface.co/settings/tokens
VUE_APP_HF_TOKEN=hf_your_token_here

# Optional: override the default model (meta-llama/Llama-3.1-8B-Instruct)
VUE_APP_HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
